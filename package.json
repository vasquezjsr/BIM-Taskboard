{
  "name": "bim-task-board",
  "version": "1.0.0",
  "description": "BIM Boardroom — project management desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n 5173,5174 \"vite --port 5173 --strictPort\" \"vite --port 5174 --strictPort\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently -k -n vite5173,vite5174,electron \"vite --port 5173 --strictPort\" \"vite --port 5174 --strictPort\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.bim.taskboard",
    "productName": "BIM Boardroom",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
