  <Target Name="GenerateWorkersAssemblyVersion" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_WorkersAsmVerOut>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'WorkersAssemblyVersion.g.cs'))))</_WorkersAsmVerOut>
    </PropertyGroup>
    <Exec Command="powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\Properties\WriteWorkersAssemblyVersion.ps1&quot; -OutputFile &quot;$(_WorkersAsmVerOut)&quot;" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)WorkersAssemblyVersion.g.cs" />
    </ItemGroup>
  </Target>
  <Target Name="RecordLastBuiltWorkersBin" AfterTargets="Build">
    <PropertyGroup>
      <_WorkersOutputDir>$([System.IO.Path]::GetFullPath('$(TargetDir)'))</_WorkersOutputDir>
      <_LocalStateDir>$(LOCALAPPDATA)\Spooling-Savant-V3-Exports</_LocalStateDir>
      <_LastBuiltWorkersBinFile>$(_LocalStateDir)\LastBuiltWorkersBin.txt</_LastBuiltWorkersBinFile>
    </PropertyGroup>
    <MakeDir Directories="$(_LocalStateDir)" />
    <WriteLinesToFile File="$(_LastBuiltWorkersBinFile)" Lines="$(_WorkersOutputDir)" Overwrite="true" Encoding="UTF-8" />
  </Target>
  <Target Name="DeployWorkersToHotloadFolders" AfterTargets="RecordLastBuiltWorkersBin" Condition="'$(SkipDeployWorkersHotload)' != 'true'">
    <PropertyGroup>
      <RevitAddinsRoot>C:\ProgramData\Autodesk\Revit\Addins</RevitAddinsRoot>
      <_WorkerPublishDir>$([System.IO.Path]::GetFullPath('$(TargetDir)').TrimEnd('\'))</_WorkerPublishDir>
    </PropertyGroup>
    <Exec Command="powershell.exe -NoLogo -NonInteractive -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\Properties\DeployWorkersHotload.ps1&quot; -SourceDir &quot;$(_WorkerPublishDir)&quot; -AddinsRoot &quot;$(RevitAddinsRoot)&quot;" IgnoreExitCode="false" />
  </Target>
