<UserControl x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.SpoolingManagerPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SpoolingSavantV3Exports.Workers.SpoolingManager.ViewModels;assembly=SpoolingSavantV3Exports.Workers"
             xmlns:views="clr-namespace:SpoolingSavantV3Exports.Workers.SpoolingManager.Views;assembly=SpoolingSavantV3Exports.Workers"
             MinWidth="340"
             MinHeight="500"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             Background="{DynamicResource SsSavantChromeBackground}">

    <Border x:Name="brdPaneShell"
            Background="{DynamicResource SsSavantChromeBackground}"
            BorderBrush="{DynamicResource SsSavantBorderOuter}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="12,8,12,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="160"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header titles — tight top so the list can grow -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Border x:Name="brdNeonSign"
                        Margin="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Padding="4,0,4,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="txtPaneTitleMain"
                                   Text="Spooling Savant"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe Script, Brush Script MT, Monotype Corsiva"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FFFFF4C8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFFC24D"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.95"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="txtPaneTitleBoardroom"
                                   Text="Together w/ BIM Boardroom"
                                   HorizontalAlignment="Center"
                                   Margin="0,-4,0,0"
                                   FontFamily="Segoe Script, Brush Script MT, Monotype Corsiva"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#FFA9F4FF">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF35D6F8"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0.85"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="txtPaneTitleMode"
                                   Text="Fabrication"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"
                                   FontFamily="Segoe Script, Brush Script MT, Monotype Corsiva"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFA9F4FF">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF35D6F8"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.95"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Spool content mode -->
            <StackPanel Grid.Row="1" Margin="0,0,0,6">
                <TextBlock Text="Spool Content"
                           Foreground="{DynamicResource SsSavantForegroundMuted}"
                           FontSize="11"
                           Margin="0,0,0,2"/>
                <ComboBox x:Name="cmbSpoolContentMode"
                          Height="30"
                          HorizontalAlignment="Stretch"
                          ToolTip="Fabrication Pipework, Families, Fabrication Ductwork-only, or Fabrication Hangers-only">
                    <ComboBoxItem Content="Fabrication" Tag="Fabrication"/>
                    <ComboBoxItem Content="Families" Tag="NativePipe"/>
                    <ComboBoxItem Content="Duct" Tag="Duct"/>
                    <ComboBoxItem Content="Hangers" Tag="Hangers"/>
                </ComboBox>
            </StackPanel>

            <!-- Search -->
            <StackPanel Grid.Row="2" Margin="0,0,0,6">
                <TextBlock Text="Search assemblies"
                           Foreground="{DynamicResource SsSavantForegroundMuted}"
                           FontSize="11"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="txtSearch"
                         Height="30"
                         ToolTip="Filters the spool list by name. This is not the package field."
                         TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <!-- Top buttons: equal width, framed so press/hover chrome is not clipped -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SsSavantListWellBackground}"
                    BorderBrush="{DynamicResource SsSavantListBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4"
                    Margin="0,0,0,6"
                    ClipToBounds="False">
                <UniformGrid Rows="1"
                             Columns="4">
                    <Button x:Name="btnRefreshList"
                            Content="Refresh List"
                            Height="28"
                            Margin="0,0,2,0"
                            Padding="6,4"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Reload assemblies from the active model"/>
                    <Button x:Name="btnClear"
                            Content="Clear"
                            Height="28"
                            Margin="2,0,2,0"
                            Padding="6,4"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Clear all checkboxes in the list"/>
                    <Button x:Name="btnIsolate"
                            Content="Isolate"
                            Height="28"
                            Margin="2,0,2,0"
                            Padding="6,4"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Temporarily isolate: checked assemblies in the list (all members) plus fabrication pipework or assemblies selected in the active model"/>
                    <Button x:Name="btnHide"
                            Content="Hide"
                            Height="28"
                            Margin="2,0,0,0"
                            Padding="6,4"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Temporarily hide: checked assemblies in the list (all members) plus fabrication pipework or assemblies selected in the active model"/>
                </UniformGrid>
            </Border>

            <!-- Assembly list area -->
            <Border Grid.Row="4"
                    Background="{DynamicResource SsSavantListWellBackground}"
                    BorderBrush="{DynamicResource SsSavantListBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="btnCollapsePackages"
                                    Content="Collapse All"
                                    Height="24"
                                    MinWidth="72"
                                    Padding="8,0"
                                    Margin="8,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Collapse every package group (S-Package) in the tree"
                                    Click="BtnCollapsePackages_Click"/>
                            <Button x:Name="btnExpandPackages"
                                    Content="Expand All"
                                    Height="24"
                                    MinWidth="68"
                                    Padding="8,0"
                                    Margin="4,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Expand every package group (S-Package) in the tree"
                                    Click="BtnExpandPackages_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="chkSelectAll"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Click="ChkSelectAll_Click"/>
                            <TextBlock Text="Spool Name"
                                       Foreground="{DynamicResource SsSavantForegroundTitle}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Divider between the header row and the assembly list -->
                    <Border Grid.Row="1"
                            Height="1"
                            Margin="-6,0,-6,0"
                            Background="{DynamicResource SsSavantListBorder}"/>

                    <!-- Recessed well: the list looks pushed into the pane -->
                    <Border Grid.Row="2"
                            Margin="-2,6,-2,-2"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#33000000"
                            Background="{DynamicResource SsSavantListWellBackground}"
                            ClipToBounds="True">
                    <Grid>
                    <ScrollViewer x:Name="scrollAssemblyTree"
                                  Margin="6,4,6,4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource SsSavantListWellBackground}">
                        <ItemsControl x:Name="treeAssemblies"
                                      Background="{DynamicResource SsSavantListWellBackground}"
                                      Foreground="{DynamicResource SsSavantForegroundPrimary}"
                                      BorderThickness="0"
                                      Padding="0"
                                      ItemsSource="{Binding}">
                            <ItemsControl.Resources>
                                <Style x:Key="PackageTitleInlineEditStyle"
                                       TargetType="TextBox">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="2,0"/>
                                    <Setter Property="CaretBrush" Value="{DynamicResource SsSavantForegroundPrimary}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SsSavantForegroundTitle}"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SsSavantInputBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SsSavantListBorder}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <DataTemplate DataType="{x:Type vm:PackageAssemblyGroup}">
                                    <Expander Margin="0,2,0,4"
                                              Background="{DynamicResource SsSavantListWellBackground}"
                                              Foreground="{DynamicResource SsSavantForegroundPrimary}"
                                              BorderBrush="{DynamicResource SsSavantBorderOuter}"
                                              BorderThickness="0,0,0,1"
                                              IsExpanded="{Binding PackageTreeExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                                <CheckBox IsThreeState="True"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"
                                                          IsChecked="{Binding HeaderCheckState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ToolTip="Select or clear all assemblies in this package"/>
                                                <TextBox MinWidth="72"
                                                         Margin="0,0,4,0"
                                                         VerticalAlignment="Center"
                                                         Style="{StaticResource PackageTitleInlineEditStyle}"
                                                         Text="{Binding DisplayTitle, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         ToolTip="Click to rename package (S-Package on every assembly in this group). Press Enter to apply, Esc to cancel."
                                                         views:SpoolingManagerPane.PackageTitleEditor="True"/>
                                                <TextBlock Text="{Binding AssemblyCountSuffix}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SsSavantForegroundTitle}"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ItemsControl Background="{DynamicResource SsSavantListWellBackground}"
                                                      Margin="12,4,0,0"
                                                      ItemsSource="{Binding Assemblies}">
                                            <ItemsControl.Resources>
                                                <DataTemplate DataType="{x:Type vm:AssemblyRow}">
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SpoolName}"
                                                                   Foreground="{DynamicResource SsSavantForegroundPrimary}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE8A5;"
                                                                   FontSize="14"
                                                                   Foreground="#9FD4FA"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,2,0"
                                                                   ToolTip="Spool sheet exists for this assembly">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasSpoolSheet}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.Resources>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Inner-shadow overlay so the well reads as concave (opposite of the raised buttons) -->
                    <Border IsHitTestVisible="False"
                            VerticalAlignment="Top"
                            Height="10"
                            CornerRadius="8,8,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#38000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border IsHitTestVisible="False"
                            HorizontalAlignment="Left"
                            Width="8"
                            CornerRadius="8,0,0,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#20000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border IsHitTestVisible="False"
                            HorizontalAlignment="Right"
                            Width="8"
                            CornerRadius="0,8,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                <GradientStop Color="#20000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border IsHitTestVisible="False"
                            VerticalAlignment="Bottom"
                            Height="6"
                            CornerRadius="0,0,8,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#18000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Package field + nine action buttons — StackPanel rows (no UniformGrid stretch) -->
            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <StackPanel Margin="0,0,0,6">
                    <TextBlock Text="Package name (parameter S-Package)"
                               Foreground="{DynamicResource SsSavantForegroundTitle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               ToolTip="Package name (parameter S-Package)"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPackageNumber"
                                 Grid.Column="0"
                                 Height="30"
                                 MinHeight="30"
                                 ToolTip="Type the package value here, select assemblies, then tap Add to Package."/>
                        <Button x:Name="btnPaneSettings"
                                Grid.Column="2"
                                Width="34"
                                Height="30"
                                Padding="0"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                ToolTip="Title blocks, tags, views, schedules, Boardroom"
                                Click="BtnSettings_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE713;"
                                       FontSize="16"
                                       Foreground="{DynamicResource SsSavantForegroundPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Every action row uses the same bottom margin (6) for even gaps -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnAddToPackage"
                            Grid.Column="0"
                            Content="Add to Package"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            HorizontalContentAlignment="Center"/>
                    <Button x:Name="btnRemoveFromPackage"
                            Grid.Column="2"
                            Content="Remove from Package"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            HorizontalContentAlignment="Center"
                            ToolTip="Clears S-Package on checked assemblies so they are no longer grouped under a package."/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnCreateSpoolSheets"
                            Grid.Column="0"
                            Content="Create Spool Sheets"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            Click="BtnCreateSpoolSheets_Click"/>
                    <Button x:Name="btnOpenSheets"
                            Grid.Column="2"
                            Content="Open Sheets"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            ToolTip="Opens every spool sheet for checked rows, in list order. Revit needs one view change per idle cycle — opens quickly in sequence."
                            Click="BtnOpenSheets_Click"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnRenameSheets"
                            Grid.Column="0"
                            Content="Rename Sheets"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            Click="BtnRenameSheets_Click"/>
                    <Button x:Name="btnRefreshSheets"
                            Grid.Column="2"
                            Content="Refresh Assembly"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            Click="BtnRefreshSheets_Click"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnCreateSpoolMap"
                            Grid.Column="0"
                            Content="Create Spool Map"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            HorizontalContentAlignment="Center"
                            ToolTip="Creates a spool map sheet for one package: 3D and plan views filtered to the package, placed on a sheet, with assembly tags on the 3D view only."/>
                    <Button x:Name="btnPlotPackages"
                            Grid.Column="2"
                            Content="Plot Packages"
                            Height="30"
                            Margin="0"
                            Padding="8,0"
                            HorizontalContentAlignment="Center"
                            ToolTip="For each checked package: writes PDF reports into the folder you choose. Existing files with the same names are overwritten — no extra naming dialogs."/>
                </Grid>

                <Button x:Name="btnExportToBoardroom"
                        Content="Export to Boardroom"
                        Height="30"
                        Margin="0"
                        Padding="8,0"
                        HorizontalContentAlignment="Center"
                        ToolTip="Exports checked packages (all reports + boardroom-package.json) for Fab and Shipping. Pick a Boardroom project from your projects CSV."/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
