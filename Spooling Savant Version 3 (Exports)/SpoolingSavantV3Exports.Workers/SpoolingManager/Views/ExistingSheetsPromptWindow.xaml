<Window x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.ExistingSheetsPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Existing Spool Sheets Found"
        Height="340"
        Width="480"
        MinHeight="280"
        MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="{DynamicResource SsSavantChromeBackground}">
    <Border BorderThickness="2"
            CornerRadius="12"
            Padding="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF131730" Offset="0"/>
                <GradientStop Color="#FF06080F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FF4DA3FF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Existing spool sheets were found for the following assemblies:"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SsSavantForegroundPrimary}"/>
                <TextBlock Text="Choose whether to skip existing sheets, regenerate them, or cancel."
                           Margin="0,4,0,0"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SsSavantForegroundMuted}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{DynamicResource SsSavantListWellBackground}"
                    BorderBrush="{DynamicResource SsSavantBorderOuter}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <ListBox x:Name="lstExistingSheets"
                         Background="{DynamicResource SsSavantListWellBackground}"
                         Foreground="{DynamicResource SsSavantForegroundPrimary}"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button x:Name="btnCancel"
                        Content="Cancel"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"/>
                <Button x:Name="btnSkipExisting"
                        Content="Skip Existing"
                        Width="110"
                        Height="30"
                        Margin="0,0,8,0"/>
                <Button x:Name="btnRegenerateExisting"
                        Content="Regenerate Existing"
                        Width="140"
                        Height="30"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
