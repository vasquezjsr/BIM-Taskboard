<Window x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.CreateAssemblyDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Spool"
        Width="440"
        MinWidth="400"
        MinHeight="340"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource SsSavantChromeBackground}">

    <Border Background="{DynamicResource SsSavantChromeBackground}"
            BorderBrush="{DynamicResource SsSavantBorderOuter}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SsSavantListWellBackground}"
                    BorderBrush="{DynamicResource SsSavantListBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Style="{DynamicResource SsSavantDialogHintText}"
                               Margin="0,0,0,12"
                               Text="If your assembly matches an existing assembly, Revit may reuse its type name and naming rules. Package Name is remembered exactly as you last confirmed until you change it. Assembly Name is remembered separately; after a successful create, a trailing number (for example CHWS-08) advances automatically for the next run."/>

                    <TextBlock Text="Package Name"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAssemblyPackageName"
                             Height="32"
                             Margin="0,0,0,10"
                             ToolTip="S-Package applied to the new assembly after creation. Remembered exactly as you enter it until you edit it (no auto-increment)."/>

                    <TextBlock Text="Assembly Name"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAssemblyName"
                             Height="32"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Naming Category"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbNamingCategory"
                              Height="32"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="88"
                        Height="32"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="Cancel"
                        Width="88"
                        Height="32"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
