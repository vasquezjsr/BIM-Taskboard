<Window x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.CreateAssemblyDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Spool"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="Transparent">

    <Border BorderThickness="2"
            CornerRadius="12"
            Padding="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF131730" Offset="0"/>
                <GradientStop Color="#FF06080F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FF4DA3FF"/>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="txtDialogTitle"
                           Text="Create Spool"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SsSavantForegroundPrimary}"/>
                <TextBlock TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource SsSavantForegroundMuted}"
                           Text="Package Name is remembered as you last confirmed. Assembly Name advances a trailing number after each successful create."/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{DynamicResource SsSavantListWellBackground}"
                    BorderBrush="{DynamicResource SsSavantBorderOuter}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Package Name"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAssemblyPackageName"
                             Height="32"
                             Margin="0,0,0,10"
                             ToolTip="S-Package applied to the new assembly after creation. Remembered exactly as you enter it until you edit it (no auto-increment)."/>

                    <TextBlock Text="Assembly Name"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAssemblyName"
                             Height="32"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Naming Category"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbNamingCategory"
                              Height="32"
                              Margin="0,0,0,12"/>

                    <CheckBox x:Name="chkChainSpooling"
                              Content="Chain Spooling"
                              VerticalContentAlignment="Center"
                              Foreground="{DynamicResource SsSavantForegroundPrimary}"
                              ToolTip="After OK, click the next part down the line. Everything between that pick and the assembly you just made becomes the next spool. Keep clicking; Esc stops."/>
                    <TextBlock Text="Click the next part along the run — parts between it and the last spool become the next assembly."
                               TextWrapping="Wrap"
                               Margin="22,4,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SsSavantForegroundMuted}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="88"
                        Height="32"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="Cancel"
                        Width="88"
                        Height="32"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
