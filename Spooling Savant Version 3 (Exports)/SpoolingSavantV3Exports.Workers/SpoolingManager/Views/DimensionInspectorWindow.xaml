<Window x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.DimensionInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dimension Inspector"
        Height="720"
        Width="1100"
        MinHeight="480"
        MinWidth="800"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SsSavantChromeBackground}">
    <Border Background="{DynamicResource SsSavantChromeBackground}"
            BorderThickness="0"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtStatus"
                       Grid.Row="0"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SsSavantForegroundPrimary}"
                       FontSize="12"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource SsSavantBorderOuter}"
                        BorderThickness="1"
                        Background="#111111">
                    <Grid>
                        <Image x:Name="imgView"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtNoImage"
                                   Text="View snapshot will appear here."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#AAAAAA"
                                   FontSize="12"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtDetails"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource SsSavantForegroundPrimary}"
                             FontFamily="Consolas"
                             FontSize="11"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SsSavantForegroundMuted}"
                           FontSize="11"
                           Text="Select a linear dimension in Revit. Move it or drag a witness — this panel updates live."/>
                <Button Grid.Column="1"
                        x:Name="btnRefresh"
                        Content="Refresh Now"
                        Width="100"
                        Height="26"
                        Click="BtnRefresh_Click"/>
                <Button Grid.Column="3"
                        Content="Close"
                        Width="80"
                        Height="26"
                        Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
