<Window x:Class="SpoolingSavantV3Exports.Workers.SpoolingManager.Views.TeachAutoDimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teach Auto-Dim"
        Height="560"
        Width="980"
        MinHeight="400"
        MinWidth="780"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5"
        Foreground="#FF1A1A1A">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
            <Setter Property="BorderBrush" Value="#FFBDBDBD"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFD6EAF8"/>
                    <Setter Property="Foreground" Value="#FF1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
            <Setter Property="MinHeight" Value="36"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFD6EAF8"/>
                    <Setter Property="Foreground" Value="#FF1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FF1A1A1A"/>
            <Setter Property="Background" Value="#FFECECEC"/>
            <Setter Property="BorderBrush" Value="#FF9E9E9E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="TeachCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Focusable" Value="True"/>
        </Style>
    </Window.Resources>
    <Border Background="#FFF5F5F5" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="160"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtStatus"
                       Grid.Row="0"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Foreground="#FF1A1A1A"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Text="Activate a dimensioned spool view, then mark each dim."/>

            <TextBlock Grid.Row="1"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       Foreground="#FF333333"
                       FontSize="12"
                       Text="Content = anchors / span / role. Placement = offset distance and side (3/8&quot; slot 0). Mark independently — e.g. right witnesses but wrong placement. Fix bad dims in Revit, Refresh, then Finish."/>

            <DataGrid x:Name="gridDims"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="All"
                      Background="#FFFFFFFF"
                      Foreground="#FF1A1A1A"
                      BorderBrush="#FF9E9E9E"
                      BorderThickness="1"
                      RowHeaderWidth="0"
                      ColumnHeaderHeight="38"
                      RowBackground="#FFFFFFFF"
                      AlternatingRowBackground="#FFF0F0F0"
                      HorizontalGridLinesBrush="#FFBDBDBD"
                      VerticalGridLinesBrush="#FFBDBDBD"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dimension"
                                        Binding="{Binding DisplayLabel}"
                                        Width="*"
                                        MinWidth="300"
                                        IsReadOnly="True"
                                        Foreground="#FF1A1A1A">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF1A1A1A"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridCheckBoxColumn Header="Content OK"
                                            Binding="{Binding ContentCorrect, UpdateSourceTrigger=PropertyChanged}"
                                            Width="88"
                                            ElementStyle="{StaticResource TeachCheckBoxStyle}"/>
                    <DataGridCheckBoxColumn Header="Content BAD"
                                            Binding="{Binding ContentIncorrect, UpdateSourceTrigger=PropertyChanged}"
                                            Width="96"
                                            ElementStyle="{StaticResource TeachCheckBoxStyle}"/>
                    <DataGridCheckBoxColumn Header="Place OK"
                                            Binding="{Binding PlacementCorrect, UpdateSourceTrigger=PropertyChanged}"
                                            Width="80"
                                            ElementStyle="{StaticResource TeachCheckBoxStyle}"/>
                    <DataGridCheckBoxColumn Header="Place BAD"
                                            Binding="{Binding PlacementIncorrect, UpdateSourceTrigger=PropertyChanged}"
                                            Width="86"
                                            ElementStyle="{StaticResource TeachCheckBoxStyle}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtHint"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#FF333333"
                           FontSize="12"
                           Text="Unmarked dims are ignored on Finish."/>
                <Button Grid.Column="1"
                        x:Name="btnRefresh"
                        Content="Refresh"
                        Width="96"
                        Height="32"
                        Click="BtnRefresh_Click"/>
                <Button Grid.Column="3"
                        x:Name="btnFinish"
                        Content="Finish"
                        Width="96"
                        Height="32"
                        FontWeight="SemiBold"
                        Click="BtnFinish_Click"/>
                <Button Grid.Column="5"
                        x:Name="btnClose"
                        Content="Close"
                        Width="88"
                        Height="32"
                        Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
