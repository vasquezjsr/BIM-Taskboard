                <Directory Id="DirParams2027" Name="Parameters">
                  <Component Id="CmpParams2027" Guid="*">
                    <File Id="FileParams2027"
                          Source="$(var.SpoolingSavantV3Exports.Workers.ProjectDir)Parameters\Spooling-Savant-V3-Exports_SharedParameters.txt"
