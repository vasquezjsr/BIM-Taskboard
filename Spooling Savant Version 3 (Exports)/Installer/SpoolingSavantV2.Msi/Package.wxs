                  </Component>
                  <Component Id="CmpSwPdb2027" Guid="*">
                    <File Id="FileSwPdb2027"
                          Source="$(var.SpoolingSavantV3Exports.Workers.TargetDir)SpoolingSavantV3Exports.Workers.pdb"
                          KeyPath="yes" />
                  </Component>
                  <Component Id="CmpBc2027" Guid="*">
                    <File Id="FileBc2027"
