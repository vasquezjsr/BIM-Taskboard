                      KeyPath="yes" />
              </Component>
              <Directory Id="DirBin2026" Name="Spooling-Savant-V3-Exports">
                <Component Id="CmpSsDll2026" Guid="*">
                  <File Id="FileSsDll2026"
                        Source="$(var.SpoolingSavantV3Exports.TargetDir)SpoolingSavantV3Exports.dll"
                        KeyPath="yes" />
                </Component>
                <Component Id="CmpSsPdb2026" Guid="*">
                  <File Id="FileSsPdb2026"
                        Source="$(var.SpoolingSavantV3Exports.TargetDir)SpoolingSavantV3Exports.pdb"
                        KeyPath="yes" />
                </Component>
                <Directory Id="DirIcons2026" Name="Icons" />
                <Directory Id="DirParams2026" Name="Parameters">
                  <Component Id="CmpParams2026" Guid="*">
