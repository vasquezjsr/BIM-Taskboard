            </Directory>

          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Revit 2027+ loads all-users manifests from Program Files, not ProgramData. Binaries stay in ProgramData (manifest uses absolute path). -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="PfAutodesk" Name="Autodesk">
        <Directory Id="PfRevit" Name="Revit">
          <Directory Id="PfAddins" Name="Addins">
            <Directory Id="PfYear2027" Name="2027">
              <Component Id="CmpManifest2027" Guid="*">
                <File Id="FileManifest2027"
                      Source="$(var.SpoolingSavantV3Exports.ProjectDir)Addins\2027\SpoolingSavantV3Exports.addin"
                      KeyPath="yes" />
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="CG_All">
      <ComponentRef Id="CmpManifest2024" />
