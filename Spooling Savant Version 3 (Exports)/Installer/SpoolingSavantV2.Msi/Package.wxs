  <Fragment>
    <ComponentGroup Id="CG_Icons2024" Directory="DirIcons2024">
      <Files Include="!(bindpath.MsiProject)\_payload\2024\Spooling-Savant-V3-Exports\Icons\**" />
    </ComponentGroup>
    <ComponentGroup Id="CG_Icons2025" Directory="DirIcons2025">
      <Files Include="!(bindpath.MsiProject)\_payload\2025\Spooling-Savant-V3-Exports\Icons\**" />
    </ComponentGroup>
    <ComponentGroup Id="CG_Icons2026" Directory="DirIcons2026">
