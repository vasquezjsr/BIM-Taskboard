<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="Spooling Savant V3 (Exports) for Autodesk Revit"
      Manufacturer="Spooling Savant V3 (Exports)"
      Version="$(var.InstallerProductVersion)"
      UpgradeCode="D8F3B2C1-AE9A-5F7D-B6C5-4E3D2F1A0B9C"
      Scope="perMachine"
      InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="medium" />

    <Feature Id="MainFeature" Title="Spooling Savant V3 (Exports)" Level="1">
      <ComponentGroupRef Id="CG_All" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DirAutodesk" Name="Autodesk">
        <Directory Id="DirRevit" Name="Revit">
          <Directory Id="DirAddins" Name="Addins">

            <Directory Id="DirYear2024" Name="2024">
              <Component Id="CmpManifest2024" Guid="*">
                <File Id="FileManifest2024"
                      Source="$(var.SpoolingSavantV3Exports.ProjectDir)Addins\2024\SpoolingSavantV3Exports.addin"
                      KeyPath="yes" />
              </Component>
              <Directory Id="DirBin2024" Name="Spooling-Savant-V3-Exports">
                <Component Id="CmpSsDll2024" Guid="*">
                  <File Id="FileSsDll2024"
                        Source="$(var.SpoolingSavantV3Exports.TargetDir)SpoolingSavantV3Exports.dll"
                        KeyPath="yes" />
                </Component>
                <Component Id="CmpSsPdb2024" Guid="*">
                  <File Id="FileSsPdb2024"
                        Source="$(var.SpoolingSavantV3Exports.TargetDir)SpoolingSavantV3Exports.pdb"
                        KeyPath="yes" />
                </Component>
                <Directory Id="DirIcons2024" Name="Icons" />
                <Directory Id="DirParams2024" Name="Parameters">
                  <Component Id="CmpParams2024" Guid="*">
                    <File Id="FileParams2024"
                          Source="$(var.SpoolingSavantV3Exports.Workers.ProjectDir)Parameters\Spooling-Savant-V3-Exports_SharedParameters.txt"
                          KeyPath="yes" />
                  </Component>
                </Directory>
                <Directory Id="DirHotload2024" Name="Hotload">
                  <Component Id="CmpSwDll2024" Guid="*">
                    <File Id="FileSwDll2024"
                          Source="$(var.SpoolingSavantV3Exports.Workers.TargetDir)SpoolingSavantV3Exports.Workers.dll"
                          KeyPath="yes" />
                  </Component>
                  <Component Id="CmpSwPdb2024" Guid="*">
                    <File Id="FileSwPdb2024"
                          Source="$(var.SpoolingSavantV3Exports.Workers.TargetDir)SpoolingSavantV3Exports.Workers.pdb"
                          KeyPath="yes" />
                  </Component>
                  <Component Id="CmpBc2024" Guid="*">
                    <File Id="FileBc2024"
                          Source="$(var.SpoolingSavantV3Exports.Workers.TargetDir)BouncyCastle.Cryptography.dll"
                          KeyPath="yes" />
                  </Component>
                  <Component Id="CmpIt2024" Guid="*">
                    <File Id="FileIt2024"
                          Source="$(var.SpoolingSavantV3Exports.Workers.TargetDir)itextsharp.dll"
                          KeyPath="yes" />
                  </Component>
                </Directory>
              </Directory>
            </Directory>

            <Directory Id="DirYear2025" Name="2025">
              <Component Id="CmpManifest2025" Guid="*">
                <File Id="FileManifest2025"
